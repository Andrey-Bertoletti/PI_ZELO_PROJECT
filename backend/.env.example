# PostgreSQL — ajuste usuário/senha/host conforme sua instalação
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/zero_marketplace?schema=public"
TEST_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/zero_marketplace_test?schema=public"

# Servidor
NODE_ENV=development
PORT=4000

# JWT — OBRIGATÓRIO trocar antes de subir.
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use chaves DIFERENTES para acesso e refresh, ambas com ao menos 32 caracteres.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://127.0.0.1:19000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# bcrypt
BCRYPT_SALT_ROUNDS=12
